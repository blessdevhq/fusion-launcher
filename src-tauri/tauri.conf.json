{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fusion Launcher",
  "version": "0.2.0",
  "identifier": "app.fusion.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Fusion Launcher",
        "width": 1360,
        "height": 840,
        "minWidth": 960,
        "minHeight": 680,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https: data: http://localhost:3000 http://127.0.0.1:3000; media-src 'self' https: http://localhost:3000 http://127.0.0.1:3000; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost http://localhost:3000 http://127.0.0.1:3000"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": ["profiles/*"],
    "createUpdaterArtifacts": "v1Compatible",
    "category": "Utility",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5RTQyODEwMDUxQ0Q3MDUKUldRRjF4d0ZFQ2prT2VhdG82OFBkbW5Ic05XSnFVVnd0Zm8xcHR5ZHl1aWtSSDJibFRIOERnZ1UK",
      "endpoints": [
        "https://github.com/MrBeastie/fusion-launcher/releases/latest/download/latest.json"
      ]
    }
  }
}
