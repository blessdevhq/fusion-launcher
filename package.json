{
  "name": "fusion-launcher",
  "version": "0.2.0",
  "description": "Source-driven Windows launcher for retro and console game libraries.",
  "author": "Fusion Launcher",
  "license": "GPL-3.0-or-later",
  "private": true,
  "homepage": "https://github.com/MrBeastie/fusion-launcher#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrBeastie/fusion-launcher.git"
  },
  "bugs": {
    "url": "https://github.com/MrBeastie/fusion-launcher/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "preview": "next start",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test scripts/*.node-test.mjs src/types/*.node-test.ts src/lib/*.node-test.ts src/stores/*.node-test.ts",
    "static-check": "node scripts/static-check.mjs",
    "source:validate": "node --experimental-strip-types scripts/validate-source-library.mjs",
    "source:add": "node --experimental-strip-types scripts/add-source-game.mjs",
    "source:template:check": "node --experimental-strip-types scripts/build-source-template-pages.mjs --check",
    "pages:build": "node --experimental-strip-types scripts/build-source-template-pages.mjs",
    "check": "npm run typecheck && npm test && npm run static-check && npm run build",
    "mvp:smoke": "node --experimental-strip-types scripts/mvp-smoke.mjs",
    "mvp:visual": "node scripts/mvp-visual.mjs",
    "mvp:package-smoke": "node scripts/mvp-package-smoke.mjs",
    "mvp:release": "npm run qa && npm run mvp:smoke && npm run mvp:visual",
    "mvp:release:windows": "node scripts/mvp-release-windows.mjs",
    "rust:test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "rust:clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "qa": "npm run check && npm run rust:test && npm run rust:fmt && npm run rust:clippy",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:vs": "scripts\\tauri-build-vs.cmd"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-store": "^2.4.3",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.25.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.9.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
